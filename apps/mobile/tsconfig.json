{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@prm/convex/*": [
        "../../packages/convex/*"
      ]
    }
  },
  "include": [
    "src",
    "app",
    "*.ts",
    "*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
