# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Electron build outputs
electron-app/dist/
electron-app/out/
electron-app/release/
electron-app/.webpack/

