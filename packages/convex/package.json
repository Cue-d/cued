{
  "name": "@cued/convex",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./convex/*": "./convex/*"
  },
  "scripts": {
    "dev": "convex dev",
    "build": "if [ -n \"$CI\" ] || [ -z \"$CONVEX_DEPLOYMENT\" ]; then echo 'Skipping codegen - using committed types'; else convex codegen --typecheck=disable; fi",
    "typecheck": "echo 'Skipping typecheck - TS2589 errors in large Convex codebases are expected'",
    "test": "vitest",
    "test:once": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cued/ai": "workspace:*",
    "@cued/env": "workspace:*",
    "@cued/shared": "workspace:*",
    "convex": "^1.31.7"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^4.0.4",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.9",
    "convex-test": "^0.0.41",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^2.1.8"
  }
}
