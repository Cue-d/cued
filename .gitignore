# PRM Project .gitignore

# ============================================================
# Node.js / Electron
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Electron build outputs
electron-app/dist/
electron-app/out/
electron-app/release/
electron-app/.webpack/
apps/electron/out/
apps/electron/dist/
apps/electron/.electron-vite/

# ============================================================
# Application Data & Caches
# ============================================================
# Local app database (contains personal data)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# PRM cache directories
.prm/
backend/.prm/

# Contact and message caches
**/cache/
**/*_cache.json

# ============================================================
# macOS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ============================================================
# IDEs & Editors
# ============================================================
# VSCode
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.ipr
*.iws

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================
# Environment & Secrets
# ============================================================
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json

# ============================================================
# Testing & Coverage
# ============================================================
**/coverage/

# Playwright
**/test-results/
**/playwright-report/
**/playwright/.cache/
**/.auth/
!**/.auth/.gitkeep
blob-report/

# ============================================================
# Build & Distribution
# ============================================================
# Packaged applications
*.dmg
*.pkg
*.app
*.exe
*.msi
*.zip
*.tar.gz

# Documentation builds
site/

# ============================================================
# iOS Widgets (Expo)
# ============================================================
# Generated widget assets and entitlements
apps/mobile/targets/widget/Assets.xcassets/
apps/mobile/targets/widget/generated.entitlements

# ============================================================
# Swift (Electron contacts CLI)
# ============================================================
# Swift Package Manager build directory
apps/electron/swift/.build/
# Swift Package.resolved (lock file - uncomment to track)
# apps/electron/swift/Package.resolved

# ============================================================
# Turborepo
# ============================================================
.turbo/

# Package build outputs
packages/*/dist/

# ============================================================
# Nango Integrations
# ============================================================
nango-integrations/build/
nango-integrations/.nango/nango.json
nango-integrations/.nango/schema.json

# TypeScript build info
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# ============================================================
# Temporary & Misc
# ============================================================
*.tmp
*.temp
tmp/
temp/
.cache/
