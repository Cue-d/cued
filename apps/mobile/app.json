{
  "expo": {
    "name": "Cued",
    "slug": "cued",
    "version": "1.0.0",
    "scheme": "cued",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.so.cued.app",
          "widgets": [
            {
              "name": "ActionCountWidget",
              "displayName": "Cued Actions",
              "description": "Shows your pending action count",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            },
            {
              "name": "ActionsListWidget",
              "displayName": "Contacts to Reply",
              "description": "People waiting for your response",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            }
          ]
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Suisse Regular.ttf",
            "./assets/fonts/Suisse Medium.ttf"
          ]
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "so.cued.app",
      "appleTeamId": "8MW6NC736H",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.so.cued.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "so.cued.app",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "so.cued.app.widget",
                  "targetName": "ActionCountWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.so.cued.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "f6e69a25-51dc-41d6-a506-979310837443"
      }
    }
  }
}
