{
  "expo": {
    "name": "Cued",
    "slug": "cued",
    "version": "1.0.0",
    "scheme": "cued",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "so.cued.app.widgets",
          "groupIdentifier": "group.so.cued.app",
          "widgets": [
            {
              "name": "ActionCountWidget",
              "displayName": "Cued Actions",
              "description": "Shows your pending action count",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            },
            {
              "name": "ActionsListWidget",
              "displayName": "Contacts to Reply",
              "description": "People waiting for your response",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Suisse Regular.ttf",
            "./assets/fonts/Suisse Medium.ttf"
          ]
        }
      ],
      "expo-image",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/splash-icon-dark.png",
            "backgroundColor": "#1C1C1E"
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "so.cued.app",
      "appleTeamId": "8MW6NC736H",
      "icon": "./assets/cued-icon.icon",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.so.cued.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "so.cued.app",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "so.cued.app.widgets",
                  "targetName": "ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.so.cued.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "f6e69a25-51dc-41d6-a506-979310837443"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f6e69a25-51dc-41d6-a506-979310837443",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    }
  }
}
