{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PRD Schema",
  "description": "Flexible schema for PRDs - author decides structure, validation is minimal",
  "type": "object",
  "required": ["project", "tasks"],
  "additionalProperties": true,
  "properties": {
    "project": {
      "type": "string",
      "description": "Name of the project or feature"
    },
    "description": {
      "type": "string",
      "description": "Brief description of what this PRD covers"
    },
    "linearIssueId": {
      "type": "string",
      "description": "Linear issue identifier (e.g., PRM-123)"
    },
    "target_stack": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Technologies and packages involved (optional)"
    },
    "decisions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Key decisions - structure is flexible"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "steps"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "description": "Task ID - any format (e.g., '1.1', 'setup', 'auth-flow')"
          },
          "phase": {
            "type": "integer",
            "minimum": 1,
            "description": "Phase number (optional)"
          },
          "mode": {
            "type": "string",
            "enum": ["hitl", "afk"],
            "default": "afk",
            "description": "hitl = human review, afk = autonomous"
          },
          "category": {
            "type": "string",
            "description": "Task category - any value (optional)"
          },
          "description": {
            "type": "string",
            "description": "What this task accomplishes"
          },
          "steps": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Steps to complete - MUST include verification (typecheck, lint, test)"
          },
          "passes": {
            "type": "boolean",
            "default": false,
            "description": "Whether task completed and verified"
          },
          "error": {
            "type": "string",
            "description": "Error message if task failed"
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Task IDs that must complete first"
          }
        }
      }
    }
  }
}
