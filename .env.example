# Get CONVEX_DEPLOYMENT from `npx convex dev` or Convex dashboard
CONVEX_DEPLOYMENT=dev:your-project-name-1234
NEXT_PUBLIC_CONVEX_URL=https://your-project-name-1234.convex.cloud

# WorkOS Auth
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=  # Must be at least 32 characters (generate with: openssl rand -base64 32)
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Vercel AI Gateway (optional - OIDC auth used on Vercel deployments)
AI_GATEWAY_API_KEY=

# EnrichLayer (LinkedIn profile enrichment)
ENRICHLAYER_API_KEY=

# PostHog Analytics
# Get from PostHog Dashboard: Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
