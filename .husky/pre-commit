#!/bin/sh

echo "Running typecheck..."
pnpm typecheck
if [ $? -ne 0 ]; then
  echo "❌ Typecheck failed. Please fix before committing."
  exit 1
fi
echo "✅ Typecheck passed"

echo "Running lint..."
pnpm lint
if [ $? -ne 0 ]; then
  echo "❌ Lint failed. Please fix before committing."
  exit 1
fi
echo "✅ Lint passed"

echo "Running Convex tests..."
cd packages/convex && pnpm test
if [ $? -ne 0 ]; then
  echo "❌ Convex tests failed. Please fix before committing."
  exit 1
fi
echo "✅ Convex tests passed"

cd ../..
