{
  "name": "@cued/electron",
  "version": "0.0.1",
  "private": true,
  "description": "Cued macOS Electron app for iMessage sync",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "npx @electron/rebuild -f -w better-sqlite3,node-mac-contacts && bash scripts/sign-dev.sh",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "electron-vite build && electron-builder --mac && node scripts/rebuild-host-native.js",
    "release": "node scripts/release.js",
    "package:unsigned": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac && node scripts/rebuild-host-native.js",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3,node-mac-contacts",
    "sign:dev": "bash scripts/sign-dev.sh",
    "postrebuild": "bash scripts/sign-dev.sh"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.70",
    "ai": "^6.0.33",
    "@cued/ai": "workspace:*",
    "@cued/convex": "workspace:*",
    "@cued/env": "workspace:*",
    "@cued/integrations": "workspace:*",
    "@cued/shared": "workspace:*",
    "@cued/ui": "workspace:*",
    "cmdk": "^1.1.1",
    "motion": "^12.15.0",
    "@statelyai/inspect": "^0.4.0",
    "better-sqlite3": "^12.6.0",
    "node-mac-contacts": "^1.7.2",
    "chokidar": "^5.0.0",
    "convex": "^1.31.7",
    "electron-liquid-glass": "^1.1.1",
    "electron-updater": "^6.7.3",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "xstate": "^5.26.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^4.0.2",
    "@tailwindcss/vite": "^4.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^39.2.7",
    "dotenv": "^17.2.3",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^2.1.8"
  }
}
