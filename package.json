{
  "name": "@cued/app",
  "version": "0.1.11",
  "private": true,
  "type": "module",
  "bin": {
    "cued": "./dist/cli.js"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "prepare": "husky",
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:native:macos": "swift build --package-path native/macos/CuedNative -c release",
    "build:app:macos": "bash scripts/build-cued-daemon-app.sh",
    "build:dmg:macos": "bash scripts/build-cued-dmg.sh",
    "build:tarball:macos": "bash scripts/build-cued-tarball.sh",
    "check:app-quality": "pnpm check:biome && pnpm build && pnpm typecheck && pnpm test",
    "check:ci-local": "sh scripts/check-ci-local.sh",
    "bootstrap:signal:macos": "bash scripts/fetch-signal-cli-macos.sh",
    "check:native:macos": "swift build --package-path native/macos/CuedNative -c release",
    "check:biome": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "permissions:macos": "bash scripts/request-macos-access.sh",
    "sign:notarize:macos": "bash scripts/sign-and-notarize-cued-app.sh",
    "test": "vitest run",
    "test:perf": "tsx src/runtime/perf/run.ts",
    "test:perf:daemon-memory": "bash scripts/bench-daemon-memory-macos.sh",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3-multiple-ciphers"
    ]
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^12.4.1",
    "drizzle-orm": "^0.45.1",
    "playwright": "^1.57.0",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.9",
    "husky": "^9.1.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
