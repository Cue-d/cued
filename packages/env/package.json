{
  "name": "@cued/env",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "react-native": "./src/server.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "react-native": "./src/client.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./convex": {
      "types": "./src/convex.ts",
      "react-native": "./src/convex.ts",
      "import": "./dist/convex.js",
      "default": "./dist/convex.js"
    },
    "./electron": {
      "types": "./src/electron.ts",
      "react-native": "./src/electron.ts",
      "import": "./dist/electron.js",
      "default": "./dist/electron.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
