# Convex Database
# Get this from your Convex dashboard: Settings → URL & Deploy Key
# Or from packages/convex/.env.local (convert CONVEX_DEPLOYMENT to URL format)
NEXT_PUBLIC_CONVEX_URL=https://your-project-name-1234.convex.cloud

# WorkOS Auth (will be added in task 1.13)
# WORKOS_CLIENT_ID=
# WORKOS_API_KEY=
# WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Nango Integration Platform (Phase 4)
# Get this from Nango Dashboard: Environment Settings → Secret Key
# See apps/web/NANGO_SETUP.md for configuration guide
NANGO_SECRET_KEY=

# OpenAI API
OPENAI_API_KEY=
# Optional: ZDR (Zero Data Retention) endpoint for production
# OPENAI_BASE_URL=https://api.openai.com/v1

# Mem0 API
MEM0_API_KEY=