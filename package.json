{
  "name": "cued",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm --dir apps/cued build",
    "build:app:macos": "bash scripts/build-cued-daemon-app.sh",
    "build:dmg:macos": "bash scripts/build-cued-dmg.sh",
    "build:tarball:macos": "bash scripts/build-cued-tarball.sh",
    "dev": "pnpm --dir apps/cued dev",
    "permissions:macos": "bash scripts/request-macos-access.sh",
    "sign:notarize:macos": "bash scripts/sign-and-notarize-cued-app.sh",
    "typecheck": "pnpm --dir apps/cued typecheck",
    "test": "pnpm --dir apps/cued test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
