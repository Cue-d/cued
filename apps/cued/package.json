{
  "name": "cued",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "cued": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:native:macos": "swift build --package-path ../../native/macos/CuedNative -c release",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:perf": "tsx src/perf/run.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.0",
    "drizzle-orm": "^0.45.1",
    "playwright": "^1.57.0",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
