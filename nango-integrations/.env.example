# Nango CLI Environment Variables
# Get keys from: Nango Dashboard → Environment Settings
# Toggle between dev/prod environments in the left nav to get each key

# Development secret key (for `nango deploy dev`)
NANGO_SECRET_KEY_DEV=nango_dev_xxxx

# Production secret key (for `nango deploy prod`)
NANGO_SECRET_KEY_PROD=nango_prod_xxxx

# Self-hosted Nango instance URL (optional, default: https://api.nango.dev)
# NANGO_HOSTPORT=http://localhost:3003
