#!/bin/sh

# Run Convex tests (required since CI excludes them due to credential requirements)
# These tests validate schema, mutations, and queries before pushing
echo "Running Convex tests..."
cd packages/convex && pnpm test
if [ $? -ne 0 ]; then
  echo "❌ Convex tests failed. Please fix before committing."
  exit 1
fi
echo "✅ Convex tests passed"

cd ../..
