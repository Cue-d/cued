# Get CONVEX_DEPLOYMENT from `npx convex dev` or Convex dashboard
CONVEX_DEPLOYMENT=dev:your-project-name-1234
NEXT_PUBLIC_CONVEX_URL=https://your-project-name-1234.convex.cloud

# WorkOS Auth
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=  # Must be at least 32 characters (generate with: openssl rand -base64 32)
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Nango Integration Platform
# Get from Nango Dashboard: Environment Settings → Secret Key
NANGO_SECRET_KEY=

# Vercel AI Gateway (optional - OIDC auth used on Vercel deployments)
AI_GATEWAY_API_KEY=

# Mem0 API
MEM0_API_KEY=
